# Copia questo file in `.env` e compila i valori.
# Il file `.env` e' gitignorato: NON verra' mai committato.

# Token del bot Telegram ottenuto da @BotFather
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUVwxyz

# Chat id dove ricevere le notifiche (vedi README per come ottenerlo)
TELEGRAM_CHAT_ID=123456789

# API key Google Books (OBBLIGATORIA: la quota anonima condivisa e' esaurita).
# Vedi README per come crearla. La stessa key va anche nell'interfaccia web.
GOOGLE_BOOKS_API_KEY=AIza...
